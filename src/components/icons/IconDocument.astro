---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 48 } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className}>
  <!-- Document outline with folded corner -->
  <path d="M12 4 L32 4 L38 10 L38 44 L12 44 Z" />
  <!-- Folded corner -->
  <path d="M32 4 L32 10 L38 10" />
  <!-- Text lines -->
  <line x1="17" y1="18" x2="33" y2="18" />
  <line x1="17" y1="24" x2="33" y2="24" />
  <line x1="17" y1="30" x2="33" y2="30" />
  <line x1="17" y1="36" x2="27" y2="36" />
</svg>
