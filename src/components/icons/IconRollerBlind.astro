---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 48 } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className}>
  <!-- Window frame -->
  <rect x="8" y="6" width="32" height="36" rx="1" />
  <!-- Roller housing at top -->
  <rect x="8" y="6" width="32" height="4" rx="1" />
  <!-- Blind fabric (partially down) -->
  <rect x="10" y="10" width="28" height="18" />
  <!-- Blind bottom edge (scalloped/rounded) -->
  <path d="M10 28 Q17 31 24 28 Q31 31 38 28" />
  <!-- Pull cord -->
  <line x1="24" y1="28" x2="24" y2="34" />
  <!-- Pull cord handle -->
  <circle cx="24" cy="35" r="1.5" />
  <!-- Window sill -->
  <line x1="6" y1="42" x2="42" y2="42" />
</svg>
