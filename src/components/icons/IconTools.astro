  <!-- Wrench -->
  <path d="M14 34 L28 20" />
  <path d="M28 20 C26 16 27 11 31 8 C33 6 36 5 39 6 L34 11 L34 15 L38 15 L43 10 C44 13 43 16 41 18 C38 21 33 22 29 20" />
  <line x1="14" y1="34" x2="10" y2="38" />
  <circle cx="9" cy="39" r="2.5" />
  <!-- Screwdriver -->
  <line x1="20" y1="28" x2="34" y2="42" />
  <path d="M20 28 L14 22 L10 18 C9 17 9 15 10 14 L14 10 C15 9 17 9 18 10 L22 14 L28 20" />
  <rect x="31.5" y="39.5" width="5" height="5" rx="1" transform="rotate(45 34 42)" />
