---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 48 } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className}>
  <!-- Door frame -->
  <rect x="10" y="4" width="28" height="40" rx="1" />
  <!-- Door panel top -->
  <rect x="14" y="8" width="20" height="14" rx="0.5" />
  <!-- Door panel bottom -->
  <rect x="14" y="26" width="20" height="14" rx="0.5" />
  <!-- Door handle -->
  <circle cx="31" cy="26" r="1.5" />
  <!-- Floor line -->
  <line x1="6" y1="44" x2="42" y2="44" />
</svg>
