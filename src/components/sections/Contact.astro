---
import Section from '../ui/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import { getLangFromUrl, getTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<Section id="kontakt" bg="white">
  <SectionHeading title={t.contact.sectionTitle} subtitle={t.contact.sectionSubtitle} />

  <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
    <!-- Contact Info -->
    <div class="lg:col-span-2" data-animate="fade-left">
      <h3 class="text-xl font-bold text-gray-900 mb-6">{t.contact.infoTitle}</h3>

      <div class="space-y-5">
        <!-- Address -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 bg-primary-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">{t.contact.address}</p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 bg-primary-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <a href="tel:+381642161008" class="font-medium text-gray-900 hover:text-primary-700 transition-colors">{t.contact.phone}</a>
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 bg-primary-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <a href="mailto:wiederbau.sombor@gmail.com" class="font-medium text-gray-900 hover:text-primary-700 transition-colors">{t.contact.email}</a>
          </div>
        </div>

        <!-- Working hours -->
        <div class="mt-8 p-5 bg-gray-50 rounded-xl">
          <h4 class="font-semibold text-gray-900 mb-3">{t.contact.workingHours}</h4>
          <div class="space-y-1.5 text-sm text-gray-600">
            <p>{t.contact.weekdays}</p>
            <p>{t.contact.saturday}</p>
            <p class="text-red-500">{t.contact.sunday}</p>
          </div>
        </div>

        <!-- Social -->
        <div class="mt-6">
          <h4 class="font-semibold text-gray-900 mb-3">{t.contact.followUs}</h4>
          <div class="flex gap-3">
            <a
              href="https://www.facebook.com/profile.php?id=100067917799799"
              target="_blank"
              rel="noopener"
              class="w-11 h-11 bg-gray-100 hover:bg-primary-700 hover:text-white text-gray-600 rounded-xl flex items-center justify-center transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
            <a
              href="https://www.instagram.com/pvc_sombor_wiederbau_veka"
              target="_blank"
              rel="noopener"
              class="w-11 h-11 bg-gray-100 hover:bg-primary-700 hover:text-white text-gray-600 rounded-xl flex items-center justify-center transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Form -->
    <div class="lg:col-span-3" data-animate="fade-right">
      <div class="bg-gray-50 rounded-2xl p-8 lg:p-10">
        <h3 class="text-xl font-bold text-gray-900 mb-6">{t.contact.formTitle}</h3>

        <form id="contact-form" class="space-y-5" action="#" method="POST">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">{t.contact.formName} *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">{t.contact.formPhone} *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">{t.contact.formEmail}</label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full rounded-xl border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none"
            />
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="city" class="block text-sm font-medium text-gray-700 mb-1.5">{t.contact.formCity} *</label>
              <select
                id="city"
                name="city"
                required
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none bg-white"
              >
                <option value="">{t.contact.formSelectPlaceholder}</option>
                {t.contact.formCityOptions.map((city: string) => (
                  <option value={city}>{city}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-1.5">{t.contact.formService} *</label>
              <select
                id="service"
                name="service"
                required
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none bg-white"
              >
                <option value="">{t.contact.formSelectPlaceholder}</option>
                {t.contact.formServiceOptions.map((service: string) => (
                  <option value={service}>{service}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">{t.contact.formMessage}</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full rounded-xl border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none resize-none"
            ></textarea>
          </div>

          <Button type="submit" variant="primary" size="lg" class="w-full">
            {t.contact.formSubmit}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </Button>
        </form>
      </div>
    </div>
  </div>
</Section>
