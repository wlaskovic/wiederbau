---
import Section from '../ui/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { getLangFromUrl, getTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<Section id="o-nama" bg="white">
  <SectionHeading title={t.about.sectionTitle} subtitle={t.about.sectionSubtitle} />

  <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Text -->
    <div data-animate="fade-left">
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        {t.about.paragraph1}
      </p>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        {t.about.paragraph2}
      </p>
      <p class="text-lg text-gray-600 leading-relaxed mb-8">
        {t.about.paragraph3}
      </p>

      <!-- Partner logos -->
      <div class="flex items-center gap-6 opacity-70">
        <div class="px-4 py-2 bg-gray-100 rounded-lg">
          <span class="text-sm font-bold text-gray-700 tracking-wider">VEKA</span>
        </div>
        <div class="px-4 py-2 bg-gray-100 rounded-lg">
          <span class="text-sm font-bold text-gray-700 tracking-wider">ALUMIL</span>
        </div>
      </div>
    </div>

    <!-- Image + Stats -->
    <div data-animate="fade-right">
      <!-- Image placeholder -->
      <div class="relative rounded-2xl overflow-hidden shadow-2xl mb-8">
        <div class="aspect-[4/3] bg-gradient-to-br from-primary-100 to-primary-200">
          <img src="/images/about/team.jpg" alt="WiederBau tim" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <!-- Accent corner -->
        <div class="absolute -bottom-2 -right-2 w-24 h-24 bg-accent-500 rounded-tl-3xl -z-10"></div>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center p-4 bg-gray-50 rounded-xl">
          <div class="text-2xl md:text-3xl font-bold text-primary-700">{t.about.stat1Value}</div>
          <div class="text-xs md:text-sm text-gray-500 mt-1">{t.about.stat1Label}</div>
        </div>
        <div class="text-center p-4 bg-gray-50 rounded-xl">
          <div class="text-2xl md:text-3xl font-bold text-primary-700">{t.about.stat2Value}</div>
          <div class="text-xs md:text-sm text-gray-500 mt-1">{t.about.stat2Label}</div>
        </div>
        <div class="text-center p-4 bg-gray-50 rounded-xl">
          <div class="text-2xl md:text-3xl font-bold text-primary-700">{t.about.stat3Value}</div>
          <div class="text-xs md:text-sm text-gray-500 mt-1">{t.about.stat3Label}</div>
        </div>
      </div>
    </div>
  </div>
</Section>
