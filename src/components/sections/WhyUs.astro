---
import Section from '../ui/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { getLangFromUrl, getTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const stats = [
  {
    value: t.whyUs.stat1Value,
    label: t.whyUs.stat1Label,
    desc: t.whyUs.stat1Desc,
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><path d="M24 4L6 14v12c0 11 8 18 18 20 10-2 18-9 18-20V14L24 4z"/><path d="M16 24l6 6 10-12"/></svg>`,
  },
  {
    value: t.whyUs.stat2Value,
    label: t.whyUs.stat2Label,
    desc: t.whyUs.stat2Desc,
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="6" y="10" width="36" height="28" rx="2"/><path d="M6 18h36"/><circle cx="24" cy="30" r="5"/><path d="M20 10V6h8v4"/></svg>`,
  },
  {
    value: t.whyUs.stat3Value,
    label: t.whyUs.stat3Label,
    desc: t.whyUs.stat3Desc,
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><path d="M8 40V20l16-12 16 12v20"/><path d="M18 40V28h12v12"/></svg>`,
  },
  {
    value: t.whyUs.stat4Value,
    label: t.whyUs.stat4Label,
    desc: t.whyUs.stat4Desc,
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="8" y="4" width="32" height="40" rx="2"/><line x1="16" y1="14" x2="32" y2="14"/><line x1="16" y1="22" x2="32" y2="22"/><line x1="16" y1="30" x2="26" y2="30"/></svg>`,
  },
];
---

<Section id="zasto-mi" bg="gray">
  <SectionHeading title={t.whyUs.sectionTitle} subtitle={t.whyUs.sectionSubtitle} />

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
    {stats.map((stat, i) => (
      <div
        class="bg-white rounded-2xl p-8 text-center shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100"
        data-animate
        style={`transition-delay: ${i * 100}ms`}
      >
        <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-50 rounded-2xl mb-5 text-primary-600">
          <Fragment set:html={stat.icon} />
        </div>
        <div class="text-2xl font-bold text-primary-700 mb-1">{stat.value}</div>
        <div class="text-lg font-semibold text-gray-900 mb-2">{stat.label}</div>
        <p class="text-sm text-gray-500">{stat.desc}</p>
      </div>
    ))}
  </div>
</Section>
