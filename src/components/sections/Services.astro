---
import Section from '../ui/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import { getLangFromUrl, getTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const services = [
  {
    title: t.services.pvcTitle,
    desc: t.services.pvcDesc,
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="6" y="6" width="36" height="36" rx="2"/><line x1="24" y1="6" x2="24" y2="42"/><line x1="6" y1="24" x2="42" y2="24"/></svg>`,
  },
  {
    title: t.services.aluTitle,
    desc: t.services.aluDesc,
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="8" y="4" width="32" height="40" rx="2"/><line x1="24" y1="4" x2="24" y2="44"/><circle cx="28" cy="24" r="1.5" fill="currentColor"/></svg>`,
  },
  {
    title: t.services.terraceTitle,
    desc: t.services.terraceDesc,
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="4" y="8" width="18" height="32" rx="1"/><rect x="20" y="8" width="24" height="32" rx="1"/><path d="M20 8l6 4"/><path d="M20 40l6-4"/></svg>`,
  },
  {
    title: t.services.blindsTitle,
    desc: t.services.blindsDesc,
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="6" y="6" width="36" height="36" rx="2"/><line x1="6" y1="12" x2="42" y2="12"/><line x1="6" y1="18" x2="42" y2="18"/><line x1="6" y1="24" x2="42" y2="24"/><rect x="6" y="6" width="36" height="4" fill="currentColor" opacity="0.2"/></svg>`,
  },
  {
    title: t.services.netsTitle,
    desc: t.services.netsDesc,
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><rect x="6" y="6" width="36" height="36" rx="2"/><path d="M6 6l36 36M42 6L6 42" opacity="0.3"/><line x1="24" y1="6" x2="24" y2="42" opacity="0.3"/><line x1="6" y1="24" x2="42" y2="24" opacity="0.3"/></svg>`,
  },
  {
    title: t.services.repairTitle,
    desc: t.services.repairDesc,
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48"><path d="M14.5 33.5L4 44"/><path d="M12 28l-3 3"/><circle cx="24" cy="18" r="10"/><path d="M33.5 27.5L44 38"/><path d="M31 25l3 3"/></svg>`,
  },
];
---

<Section id="usluge" bg="gray">
  <SectionHeading title={t.services.sectionTitle} subtitle={t.services.sectionSubtitle} />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    {services.map((service, i) => (
      <Card title={service.title} description={service.desc} delay={i * 100}>
        <Fragment slot="icon" set:html={service.icon} />
      </Card>
    ))}
  </div>
</Section>
