---
import Section from '../ui/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { getLangFromUrl, getTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const cities = t.areas.cities;

const cityCoords: Record<string, { lat: number; lng: number }> = {
  'Sombor': { lat: 45.7747, lng: 19.1128 },
  'Odžaci': { lat: 45.5089, lng: 19.2622 },
  'Crvenka': { lat: 45.6569, lng: 19.4456 },
  'Apatin': { lat: 45.6711, lng: 18.9853 },
  'Subotica': { lat: 46.1003, lng: 19.6658 },
  'Kula': { lat: 45.6078, lng: 19.5303 },
  'Bačka Topola': { lat: 45.8147, lng: 19.6328 },
};
---

<Section id="podrucje" bg="gray">
  <SectionHeading title={t.areas.sectionTitle} subtitle={t.areas.sectionSubtitle} />

  <div class="max-w-4xl mx-auto">
    <p class="text-center text-lg text-gray-600 mb-12" data-animate>
      {t.areas.description}
    </p>

    <!-- Cities grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" data-animate>
      {cities.map((city: string, i: number) => (
        <button
          class={`city-btn flex items-center gap-3 p-4 rounded-xl border transition-all duration-300 cursor-pointer text-left ${
            i === 0
              ? 'bg-primary-700 text-white border-primary-700 shadow-lg active'
              : 'bg-white text-gray-700 border-gray-200 hover:border-primary-300 hover:shadow-md'
          }`}
          data-lat={cityCoords[city]?.lat}
          data-lng={cityCoords[city]?.lng}
          data-city={city}
        >
          <svg class={`w-5 h-5 shrink-0 city-icon ${i === 0 ? 'text-accent-400' : 'text-primary-500'}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="font-medium">{city}</span>
        </button>
      ))}
    </div>

    <!-- Map embed -->
    <div class="mt-12 rounded-2xl overflow-hidden shadow-lg border border-gray-200" data-animate>
      <iframe
        id="area-map"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d90000!2d19.1128!3d45.7747!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x475cb51ab1b2e5f3%3A0xa429f9b0fc25a467!2sSombor!5e0!3m2!1ssr!2srs!4v1"
        width="100%"
        height="300"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="WiederBau Sombor location"
      ></iframe>
    </div>
  </div>
</Section>

<script>
  document.querySelectorAll('.city-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const lat = el.dataset.lat;
      const lng = el.dataset.lng;
      const city = el.dataset.city;

      // Update active state
      document.querySelectorAll('.city-btn').forEach((b) => {
        b.classList.remove('bg-primary-700', 'text-white', 'border-primary-700', 'shadow-lg', 'active');
        b.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
        b.querySelector('.city-icon')?.classList.remove('text-accent-400');
        b.querySelector('.city-icon')?.classList.add('text-primary-500');
      });
      el.classList.add('bg-primary-700', 'text-white', 'border-primary-700', 'shadow-lg', 'active');
      el.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
      el.querySelector('.city-icon')?.classList.add('text-accent-400');
      el.querySelector('.city-icon')?.classList.remove('text-primary-500');

      // Update map
      if (lat && lng && city) {
        const iframe = document.getElementById('area-map') as HTMLIFrameElement;
        if (iframe) {
          const encodedCity = encodeURIComponent(city);
          iframe.src = `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d90000!2d${lng}!3d${lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s!2s${encodedCity}!5e0!3m2!1ssr!2srs!4v1`;
        }
      }
    });
  });
</script>
