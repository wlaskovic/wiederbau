---
import { getLangFromUrl, getTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const base = lang === 'sr' ? '' : `/${lang}`;

const links = [
  { label: t.nav.about, href: `${base}/#o-nama` },
  { label: t.nav.services, href: `${base}/#usluge` },
  { label: t.nav.products, href: `${base}/#proizvodi` },
  { label: t.nav.gallery, href: `${base}/#galerija` },
  { label: t.nav.contact, href: `${base}/#kontakt` },
];
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <span class="text-2xl font-bold text-white">
          Wieder<span class="text-accent-400">Bau</span>
        </span>
        <p class="mt-4 text-sm leading-relaxed text-gray-400">
          {t.footer.description}
        </p>
        <!-- Social -->
        <div class="flex gap-3 mt-6">
          <a
            href="https://www.facebook.com/profile.php?id=100067917799799"
            target="_blank"
            rel="noopener"
            class="w-10 h-10 bg-gray-800 hover:bg-primary-700 rounded-lg flex items-center justify-center transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a
            href="https://www.instagram.com/pvc_sombor_wiederbau_veka"
            target="_blank"
            rel="noopener"
            class="w-10 h-10 bg-gray-800 hover:bg-primary-700 rounded-lg flex items-center justify-center transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">{t.footer.quickLinks}</h4>
        <ul class="space-y-3">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4">{t.footer.contactTitle}</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {t.contact.address}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <a href="tel:+381642161008" class="hover:text-white transition-colors">{t.contact.phone}</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:wiederbau.sombor@gmail.com" class="hover:text-white transition-colors">{t.contact.email}</a>
          </li>
        </ul>
      </div>

      <!-- Working Hours -->
      <div>
        <h4 class="text-white font-semibold mb-4">{t.contact.workingHours}</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>{t.contact.weekdays}</li>
          <li>{t.contact.saturday}</li>
          <li>{t.contact.sunday}</li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-800 mt-12 pt-8 text-center text-sm text-gray-500">
      {t.footer.copyright}
    </div>
  </div>
</footer>
