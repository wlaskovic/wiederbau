---
import { locales, getLangFromUrl, getLocalePath, type Lang } from '../i18n';

const currentLang = getLangFromUrl(Astro.url);
const currentLocale = locales.find(l => l.code === currentLang)!;
---

<div class="relative" id="lang-switcher">
  <button
    id="lang-btn"
    class="lang-btn flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-white hover:bg-white/10 transition-colors"
    aria-label="Change language"
  >
    <span class="text-base">{currentLocale.flag}</span>
    <span class="hidden sm:inline">{currentLocale.code.toUpperCase()}</span>
    <svg class="w-3.5 h-3.5 transition-transform" id="lang-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </button>
  <div
    id="lang-dropdown"
    class="absolute right-0 top-full mt-2 bg-white rounded-xl shadow-xl border border-gray-100 py-2 min-w-[140px] opacity-0 invisible translate-y-1 transition-all duration-200 z-50"
  >
    {locales.map((locale) => (
      <a
        href={getLocalePath(locale.code)}
        class={`flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-gray-50 transition-colors ${
          locale.code === currentLang ? 'text-primary-700 font-semibold bg-primary-50' : 'text-gray-700'
        }`}
      >
        <span class="text-base">{locale.flag}</span>
        <span>{locale.name}</span>
      </a>
    ))}
  </div>
</div>

<script>
  const btn = document.getElementById('lang-btn');
  const dropdown = document.getElementById('lang-dropdown');
  const chevron = document.getElementById('lang-chevron');
  let open = false;

  function toggle() {
    open = !open;
    if (open) {
      dropdown?.classList.remove('opacity-0', 'invisible', 'translate-y-1');
      dropdown?.classList.add('opacity-100', 'visible', 'translate-y-0');
      chevron?.classList.add('rotate-180');
    } else {
      dropdown?.classList.add('opacity-0', 'invisible', 'translate-y-1');
      dropdown?.classList.remove('opacity-100', 'visible', 'translate-y-0');
      chevron?.classList.remove('rotate-180');
    }
  }

  btn?.addEventListener('click', toggle);
  document.addEventListener('click', (e) => {
    if (open && !document.getElementById('lang-switcher')?.contains(e.target as Node)) {
      toggle();
    }
  });
</script>
