---
interface Props {
  title: string;
  description: string;
  class?: string;
  delay?: number;
}

const { title, description, class: className = '', delay = 0 } = Astro.props;
---

<div
  class={`group bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 hover:-translate-y-1 ${className}`}
  data-animate
  style={delay ? `transition-delay: ${delay}ms` : ''}
>
  <div class="mb-5 text-primary-600 group-hover:text-primary-700 transition-colors">
    <slot name="icon" />
  </div>
  <h3 class="text-xl font-semibold text-gray-900 mb-3">{title}</h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
  <slot name="footer" />
</div>
