---
interface Props {
  value: string;
  label: string;
  description?: string;
}

const { value, label, description } = Astro.props;
---

<div class="text-center p-6" data-animate>
  <div class="mb-4 flex justify-center text-primary-600">
    <slot name="icon" />
  </div>
  <div class="text-3xl md:text-4xl font-bold text-primary-700 mb-2" data-counter={value}>
    {value}
  </div>
  <div class="text-lg font-semibold text-gray-900 mb-1">{label}</div>
  {description && (
    <p class="text-sm text-gray-500 max-w-xs mx-auto">{description}</p>
  )}
</div>
